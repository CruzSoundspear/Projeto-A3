    {
      "parameters": {
        "jsCode": "// Recebe o texto do webhook\nconst texto = $input.first().json.query?.texto || \"sem texto\";\nconst lower = texto.toLowerCase()\n  .normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\"); // remove acentos\n\n// Lista expandida de palavras-chave\nconst positivas = [\n  \"bom\", \"otimo\", \"excelente\", \"feliz\", \"incrivel\",\n  \"perfeito\", \"maravilhoso\", \"adorei\", \"amei\", \"satisfeito\",\n  \"satisfeita\", \"fantastico\", \"fantastica\", \"top\", \"legal\",\n  \"rapido\", \"eficiente\", \"recomendo\", \"gostei\", \"show\"\n];\n\nconst negativas = [\n  \"ruim\", \"pessimo\", \"pessima\", \"horrivel\", \"triste\",\n  \"terrivel\", \"odeio\", \"detestei\", \"odiei\", \"decepcionante\",\n  \"decepcionado\", \"decepcionada\", \"lento\", \"quebrado\",\n  \"nao funciona\", \"nao gostei\", \"nao recomendo\", \"problema\",\n  \"defeito\", \"falhou\"\n];\n\n// Detecta negacao simples (ex: \"nao e bom\" → negativo)\nconst temNegacao = /(nao|nunca|jamais)\\s+\\w*/.test(lower);\n\nlet sentimento = \"neutro\";\n\nif (!temNegacao && positivas.some(p => lower.includes(p))) {\n  sentimento = \"positivo\";\n} else if (temNegacao || negativas.some(n => lower.includes(n))) {\n  sentimento = \"negativo\";\n}\n\nreturn [{ json: { texto, sentimento } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        -32
      ],
