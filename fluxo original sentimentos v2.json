        "jsCode": "// Registra o resultado no log CSV\nconst texto = $input.first().json.texto || \"sem texto\";\nconst sentimento = $input.first().json.sentimento || \"desconhecido\";\nconst data = new Date().toISOString();\n\nconst linha = `${data},\"${texto}\",${sentimento}\\n`;\n\nreturn [{ json: { csv_linha: linha, texto, sentimento, status: \"salvo no log\" } }];"
